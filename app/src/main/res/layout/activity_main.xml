<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/m3_surface">

    <!-- ====== TOP AREA ====== -->
    <FrameLayout
        android:id="@+id/topArea"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/m3_surface">

        <!-- Top bar: título, fecha, 3 IconButtons -->
        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="48dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/appTitle"
                    style="?attr/textAppearanceTitleLarge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name_description"
                    android:textColor="@color/m3_on_surface" />

                <TextView
                    android:id="@+id/dateText"
                    style="?attr/textAppearanceLabelMedium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.55"
                    android:textColor="@color/m3_on_surface" />
            </LinearLayout>

            <!-- 4 IconButtons verticales -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <ImageButton
                    android:id="@+id/settingsButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/content_desc_settings"
                    android:src="@android:drawable/ic_menu_manage"
                    android:tint="@color/m3_on_surface" />

                <ImageButton
                    android:id="@+id/calendarButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/content_desc_calendar"
                    android:src="@drawable/ic_calendar"
                    android:tint="@color/m3_on_surface" />

                <ImageButton
                    android:id="@+id/exportCsvIconButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/export_csv"
                    android:src="@drawable/ic_csv_export"
                    android:tint="@color/m3_on_surface" />

                <ImageButton
                    android:id="@+id/importCsvIconButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/import_csv"
                    android:src="@drawable/ic_csv_import"
                    android:tint="@color/m3_on_surface" />

                <ImageButton
                    android:id="@+id/themeToggleButton"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/content_desc_theme_toggle"
                    android:src="@drawable/ic_sun"
                    android:tint="@color/m3_on_surface" />

            </LinearLayout>
        </LinearLayout>

        <!-- Emoji grande centrado -->
        <TextView
            android:id="@+id/emojiText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="-60dp"
            android:text="😌"
            android:textSize="64sp" />

        <!-- Números CBD / THC -->
        <LinearLayout
            android:id="@+id/dualCounterContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="60dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/cbdCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="56sp"
                android:textStyle="bold"
                android:textColor="@color/m3_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" / "
                android:textSize="36sp"
                android:textColor="@color/m3_outline" />

            <TextView
                android:id="@+id/thcCountText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="56sp"
                android:textStyle="bold"
                android:textColor="@color/m3_tertiary" />
        </LinearLayout>

        <!-- Labels CBD / THC -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="160dp"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="CBD"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/m3_secondary" />

            <View android:layout_width="48dp" android:layout_height="1dp" />

            <TextView
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="THC"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/m3_tertiary" />
        </LinearLayout>

        <!-- Icono búsqueda (mantener compatibilidad) -->
        <ImageButton
            android:id="@+id/searchButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:src="@android:drawable/ic_menu_search"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/content_desc_search"
            android:tint="@color/m3_on_surface_variant" />

        <!-- TextView oculto para compatibilidad -->
        <TextView
            android:id="@+id/counterText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:text="0" />
    </FrameLayout>

    <!-- ====== BOTTOM SHEET ====== -->
    <LinearLayout
        android:id="@+id/bottomSheetContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/m3_surface_variant"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_peekHeight="260dp"
        app:behavior_hideable="false">

        <!-- Handle -->
        <View
            android:layout_width="36dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"
            android:background="@color/m3_outline" />

        <!-- FAB extendido CBD -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/addInfusedButton"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginHorizontal="16dp"
            android:text="@string/add_infused_label"
            android:textSize="15sp"
            android:textAllCaps="false"
            app:cornerRadius="26dp"
            app:backgroundTint="@color/m3_secondary" />

        <!-- Chip Estadísticas → DashboardActivity -->
        <com.google.android.material.chip.Chip
            android:id="@+id/statsChip"
            style="@style/Widget.MaterialComponents.Chip.Action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:text="@string/stats_chip_label"
            android:textSize="14sp"
            android:textAllCaps="false" />

        <!-- Fila stats -->
        <LinearLayout
            android:id="@+id/statsContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/avgText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/avg_placeholder"
                android:textSize="12sp"
                android:textColor="@color/m3_on_surface_variant" />

            <TextView
                android:id="@+id/totalText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/total_placeholder"
                android:textSize="12sp"
                android:textColor="@color/m3_on_surface_variant" />

            <TextView
                android:id="@+id/streakText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="@string/streak_placeholder"
                android:textSize="12sp"
                android:textColor="@color/m3_on_surface_variant" />
        </LinearLayout>

        <!-- Botones de control -->
        <LinearLayout
            android:id="@+id/buttonContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/subtractButton"
                style="@style/Widget.Material3.Button.TonalButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/subtract_button_label"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/addButton"
                style="@style/Widget.Material3.Button"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/add_thc_label"
                android:textAllCaps="false"
                android:layout_marginHorizontal="8dp"
                app:backgroundTint="@color/m3_tertiary" />

            <Button
                android:id="@+id/resetButton"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="@string/reset_button_label"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <!-- Tabs historial -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tabLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@color/m3_surface_variant"
            app:tabMode="fixed"
            app:tabGravity="fill" />

        <!-- RecyclerView historial -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/historyRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp"
            android:clipToPadding="false" />

    </LinearLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
